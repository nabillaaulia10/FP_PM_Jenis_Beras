   "source": [
    "from ultralytics import YOLO\n",
    "import cv2\n",
    "\n",
    "model = YOLO(\"runs/detect/train/weights/best.pt\")\n",
    "\n",
    "img = cv2.imread(\"test.jpg\")\n",
    "\n",
    "results = model(img)\n",
    "\n",
    "for r in results:\n",
    "    annotated = r.plot()\n",
    "\n",
    "cv2.imshow(\"YOLO Detection\", annotated)\n",
    "cv2.waitKey(0)\n",
    "cv2.destroyAllWindows()"
   ]
  }
